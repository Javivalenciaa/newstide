import urllib.request

def ping_google(domain="https://tudominio.com"):
    sitemap_url = f"{domain}/sitemap.xml"
    try:
        # Ping Google
        url = f"https://www.google.com/ping?sitemap={sitemap_url}"
        urllib.request.urlopen(url, timeout=10)
        print(f"  ✅ Google pingeado con sitemap")

        # Ping Bing también (gratis)
        bing_url = f"https://www.bing.com/ping?sitemap={sitemap_url}"
        urllib.request.urlopen(bing_url, timeout=10)
        print(f"  ✅ Bing pingeado")
    except Exception as e:
        print(f"  ⚠️  Ping fallido (no crítico): {e}")
